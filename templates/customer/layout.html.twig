<!DOCTYPE html>
<html>
<head>
<title>FreshBasket Dumaguete</title>

<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Roboto&display=swap" rel="stylesheet">

<style>
:root {
    --deep:#255612;
    --olive:#818234;
    --light:#DFE1A0;
    --gold:#D5921F;
}

body {
    margin:0;
    font-family:Roboto;
    background:#f8faf7;
}

header {
    background:var(--deep);
    padding:20px 40px;
    display:flex;
    justify-content:space-between;
    align-items:center;
}

header h1 {
    color:white;
    font-family:Montserrat;
    margin:0;
}

nav a {
    color:white;
    margin-left:20px;
    text-decoration:none;
    font-weight:bold;
}

nav a:hover { color:var(--gold); }

.hero {
    padding:80px 40px;
    text-align:center;
    background:linear-gradient(135deg,var(--light),white);
}

.hero h2 {
    font-family:Montserrat;
    color:var(--deep);
    font-size:36px;
}

.container {
    padding:60px 40px;
}

.card {
    background:white;
    padding:25px;
    border-radius:14px;
    box-shadow:0 6px 18px rgba(0,0,0,.05);
    margin-bottom:20px;
}

button {
    padding:10px 18px;
    border:none;
    border-radius:8px;
    background:var(--deep);
    color:white;
    cursor:pointer;
}

button:hover { background:var(--olive); }

.grid {
    display:grid;
    grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
}
</style>
</head>

<body>

<header>
    <h1>FreshBasket</h1>
    <nav>
        <a href="{{ path('app_customer_home') }}">Home</a>
        <a href="{{ path('app_customer_shop') }}">Shop</a>
        <a href="{{ path('app_customer_about') }}">About</a>
        <a href="{{ path('app_customer_services') }}">Services</a>
        <a href="{{ path('app_customer_contact') }}">Contact</a>
        <a href="{{ path('app_customer_cart') }}">Cart</a>
        <a href="{{ path('app_logout') }}">Logout</a>
    </nav>
</header>

{% block body %}{% endblock %}

</body>
</html>
