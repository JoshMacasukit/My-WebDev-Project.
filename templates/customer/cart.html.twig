{% extends 'customer/layout.html.twig' %}
{% block body %}

<h1>Your Cart</h1>

{% if cart is empty %}
    <div class="card">Your cart is empty.</div>
{% else %}

    {% for item in cart %}
        <div class="card">
            {{ item.name }} — ₱{{ item.price }}
        </div>
    {% endfor %}

    <div class="card">
        <strong>Total:</strong> ₱{{ total }}
    </div>

    <form method="post" action="{{ path('app_customer_checkout') }}">
        <button>Checkout</button>
    </form>

{% endif %}

{% endblock %}
