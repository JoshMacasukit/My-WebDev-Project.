<!DOCTYPE html>
<html>
<head>
    <title>Admin | FreshBasket Dumaguete</title>

    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Roboto&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        :root {
            --deep: #255612;
            --olive: #818234;
            --light: #DFE1A0;
            --gold: #D5921F;
            --muted: #C1C074;
        }

        * { box-sizing: border-box; }

        body {
            margin:0;
            display:flex;
            font-family:Roboto;
            background:#f4f6f8;
        }

        aside {
            width:260px;
            background:var(--deep);
            color:#fff;
            padding:30px 20px;
            min-height:100vh;
        }

        aside h2 {
            font-family:Montserrat;
            margin-bottom:30px;
        }

        aside a {
            display:block;
            padding:12px;
            margin-bottom:10px;
            color:#fff;
            text-decoration:none;
            border-radius:8px;
            transition:.2s;
        }

        aside a:hover {
            background:var(--olive);
        }

        main {
            flex:1;
            padding:40px;
        }

        h2 {
            font-family:Montserrat;
            color:var(--gold);
            margin-bottom:20px;
        }

        .card {
            background:white;
            padding:25px;
            border-radius:14px;
            margin-bottom:20px;
            box-shadow:0 8px 25px rgba(0,0,0,.05);
        }

        .btn {
            padding:8px 14px;
            border-radius:8px;
            border:none;
            cursor:pointer;
            font-weight:bold;
        }

        .btn-primary { background:var(--deep); color:white; }
        .btn-edit { background:var(--gold); color:white; }
        .btn-delete { background:#c0392b; color:white; }
        .btn-secondary { background:var(--olive); color:white; }

        input, select {
            padding:8px;
            border-radius:8px;
            border:1px solid #ccc;
            margin:5px 0;
        }

        .stats-grid {
            display:grid;
            grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
            gap:20px;
            margin-bottom:30px;
        }

        .stat-box {
            background:white;
            padding:20px;
            border-radius:14px;
            text-align:center;
            box-shadow:0 5px 15px rgba(0,0,0,.05);
        }

        .stat-box h3 {
            margin:0;
            font-size:26px;
            color:var(--deep);
        }

        .flash {
            background:var(--muted);
            padding:12px;
            border-radius:8px;
            margin-bottom:20px;
        }
    </style>
</head>

<body>

<aside>
    <h2>FreshBasket</h2>
    <a href="{{ path('app_admin') }}">Dashboard</a>
    <a href="{{ path('app_admin_products') }}">Products</a>
    <a href="{{ path('app_admin_orders') }}">Orders</a>
    <a href="{{ path('app_admin_users') }}">Users</a>
    <a href="{{ path('app_admin_reports') }}">Reports</a>
    <a href="{{ path('app_logout') }}">Logout</a>
</aside>

<main>

{% for message in app.flashes('success') %}
    <div class="flash">{{ message }}</div>
{% endfor %}

{% block body %}{% endblock %}

</main>

</body>
</html>
